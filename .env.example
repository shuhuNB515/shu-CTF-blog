# shu-CTF Blog 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ========== 必填 ==========

# DeepSeek API 密钥（用于 AI Agent 对话功能）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ========== 可选 ==========

# 后端服务端口（默认 5000）
PORT=5000

# 生产模式标识（设为 1 启用 waitress 生产服务器）
RENDER=
